  <entry>
    <title>我的简历</title>
    <link href="https://jasontsang.dev/2018/05/30/resume/"/>
    <id>https://jasontsang.dev/2018/05/30/resume/</id>
    <published>2018-05-30T05:18:42.000Z</published>
